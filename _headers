/*
  # Segurança forte
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), fullscreen=(self), payment=()

  # Conteúdo seguro
  Content-Security-Policy:
    default-src 'self';
    img-src 'self' data:;
    style-src 'self' 'unsafe-inline';
    script-src 'self' https://forms.office.com https://forms.microsoft.com https://forms.cloud.microsoft;
    frame-src https://forms.office.com https://forms.microsoft.com https://forms.cloud.microsoft;
    connect-src 'self';
    font-src 'self' data:;
    object-src 'none';
    base-uri 'self';
    form-action 'self';

  # Cache moderado
  Cache-Control: public, max-age=3600
